{
    "name": "lastword-listener",
    "version": "1.0.0",
    "description": "LastWord dead man's switch — off-chain trigger listener",
    "main": "dist/index.js",
    "engines": {
        "node": "18.x"
    },
    "scripts": {
        "build": "tsc",
        "postbuild": "mkdir -p dist/idl && cp src/idl/lastword.json dist/idl/lastword.json",
        "start": "node dist/index.js",
        "dev": "nodemon --exec ts-node src/index.ts",
        "tunnel": "npx ngrok http 3001"
    },
    "dependencies": {
        "@coral-xyz/anchor": "^0.30.1",
        "@solana/spl-token": "^0.4.6",
        "@solana/web3.js": "^1.98.4",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "node-fetch": "^2.7.0",
        "tweetnacl": "^1.0.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.25",
        "@types/node": "^20.19.39",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
